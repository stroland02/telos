{
  "statusLine": {
    "type": "command",
    "command": "telos status --line"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "telos-hook"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "telos grep-assist --hook"
          }
        ]
      }
    ]
  }
}
